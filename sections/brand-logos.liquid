{%- comment -%}
  Section: Brand Partner Logos (Foesta Edition)
  Monochromatic brand partner logos carousel/row.
{%- endcomment -%}

<section class="ds-brands-foesta" id="section-{{ section.id }}">
  <div class="ds-container">
    <div class="ds-brands-foesta__row">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="ds-brands-foesta__item" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 300 | image_tag: loading: 'lazy', alt: block.settings.title | escape }}
            {%- else -%}
              <span class="ds-brands-foesta__text-logo">{{ block.settings.title | default: 'BRAND' }}</span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- assign brand_names = 'VERSACE,GUCCI,PRADA,CHANEL,ZARA,DIOR' | split: ',' -%}
        {%- for b in brand_names -%}
          <div class="ds-brands-foesta__item">
            <span class="ds-brands-foesta__text-logo">{{ b }}</span>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
/* ═══ BRAND LOGOS (FOESTA EDITION) ═══ */
.ds-brands-foesta {
  padding: 3rem 0;
  background: #FFFFFF;
  border-top: 1px solid var(--color-border-light);
  border-bottom: 1px solid var(--color-border-light);
}

.ds-brands-foesta__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-8);
  flex-wrap: wrap;
}

.ds-brands-foesta__item {
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.55;
  filter: grayscale(100%);
  transition: opacity 250ms ease, filter 250ms ease;
}

.ds-brands-foesta__item:hover {
  opacity: 1;
  filter: grayscale(0%);
}

.ds-brands-foesta__item img {
  max-height: 36px;
  width: auto;
}

.ds-brands-foesta__text-logo {
  font-family: var(--font-heading);
  font-size: 1.25rem;
  font-weight: 800;
  letter-spacing: 0.15em;
  color: #121316;
}

@media (max-width: 767px) {
  .ds-brands-foesta__row {
    justify-content: center;
    gap: var(--space-6);
  }
}
</style>

{% schema %}
{
  "name": "Brand Partner Logos",
  "tag": "section",
  "class": "section-brand-logos",
  "max_blocks": 8,
  "settings": [],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand Logo",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Brand name",
          "default": "BRAND"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Brand logo image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Partner Logos",
      "blocks": [
        { "type": "brand", "settings": { "title": "VERSACE" } },
        { "type": "brand", "settings": { "title": "GUCCI" } },
        { "type": "brand", "settings": { "title": "PRADA" } },
        { "type": "brand", "settings": { "title": "CHANEL" } },
        { "type": "brand", "settings": { "title": "ZARA" } },
        { "type": "brand", "settings": { "title": "DIOR" } }
      ]
    }
  ]
}
{% endschema %}
