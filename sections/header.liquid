{%- comment -%}
  Section: WoodMart Dual-Row Header (Foesta Edition with Custom Brand Colors & Large Typography)
{%- endcomment -%}

{%- render 'header-drawer' -%}

<header class="wm-header" id="section-{{ section.id }}">

  {%- comment -%} ════ DESKTOP HEADER (MIN-WIDTH: 990PX) ════ {%- endcomment -%}
  <div class="wm-header__desktop small-hide medium-hide">

    {%- comment -%} TOP MAIN ROW {%- endcomment -%}
    <div class="wm-header__top-row ds-container">
      {%- comment -%} Brand Logo {%- endcomment -%}
      <div class="wm-header__logo">
        <a href="{{ routes.root_url }}" class="wm-header__logo-link">
          {%- if settings.logo != blank -%}
            {{ settings.logo | image_url: width: 400 | image_tag: class: 'wm-header__logo-img', alt: shop.name }}
          {%- else -%}
            <span class="wm-header__logo-text">{{ section.settings.logo_text | default: shop.name }}<span>.</span></span>
          {%- endif -%}
        </a>
      </div>

      {%- comment -%} Centered Search Bar {%- endcomment -%}
      <div class="wm-header__search-container">
        <form action="{{ routes.search_url }}" method="get" role="search" class="wm-header__search-form">
          <input
            type="search"
            name="q"
            class="wm-header__search-input"
            placeholder="{{ section.settings.search_placeholder | default: 'Search for products...' }}"
            aria-label="Search for products"
            autocomplete="off"
          >
          <button type="submit" class="wm-header__search-btn" aria-label="Search">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </button>
        </form>
      </div>

      {%- comment -%} Support Badges {%- endcomment -%}
      <div class="wm-header__support-badges">
        <div class="wm-support-badge">
          <div class="wm-support-badge__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div class="wm-support-badge__info">
            <span class="wm-support-badge__title">24/7 Support</span>
            <span class="wm-support-badge__value">{{ section.settings.support_phone | default: '+1 (800) 123-4567' }}</span>
          </div>
        </div>

        <div class="wm-support-badge">
          <div class="wm-support-badge__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <div class="wm-support-badge__info">
            <span class="wm-support-badge__title">Worldwide</span>
            <span class="wm-support-badge__value wm-support-badge__value--accent">{{ section.settings.shipping_text | default: 'Free Shipping' }}</span>
          </div>
        </div>
      </div>
    </div>

    {%- comment -%} BOTTOM NAVIGATION ROW {%- endcomment -%}
    <div class="wm-header__bottom-bar">
      <div class="ds-container wm-header__nav-container">

        {%- comment -%} All Categories Dropdown Button & Menu {%- endcomment -%}
        <div class="wm-categories-dropdown">
          <button type="button" class="wm-categories-btn" id="wm-categories-trigger">
            <span class="wm-categories-btn__icon-bg">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </span>
            <span class="wm-categories-btn__text">All Categories</span>
          </button>

          {%- comment -%} Vertical Dropdown Panel {%- endcomment -%}
          <div class="wm-categories-panel">
            <ul class="wm-categories-list">
              {%- assign cat_menu = section.settings.categories_menu | default: section.settings.menu -%}
              {%- for link in cat_menu.links -%}
                <li class="wm-categories-item">
                  <a href="{{ link.url }}" class="wm-categories-link">
                    <span class="wm-categories-link__icon">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                    </span>
                    <span class="wm-categories-link__title">{{ link.title | escape }}</span>
                    {%- if link.links.size > 0 -%}
                      <svg class="wm-categories-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                    {%- endif -%}
                  </a>
                </li>
              {%- else -%}
                {%- assign default_cats = 'Girls Fashion,Mens Fashion,New Arrivals,Top Sales,Winter Fashion,Home Decor,Accessories' | split: ',' -%}
                {%- for cat in default_cats -%}
                  <li class="wm-categories-item">
                    <a href="/collections/all" class="wm-categories-link">
                      <span class="wm-categories-link__icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                      </span>
                      <span class="wm-categories-link__title">{{ cat }}</span>
                      <svg class="wm-categories-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                    </a>
                  </li>
                {%- endfor -%}
              {%- endfor -%}
            </ul>
          </div>
        </div>

        {%- comment -%} Main Navigation Menu {%- endcomment -%}
        <nav class="wm-header__main-nav">
          <ul class="wm-main-menu">
            {%- for link in section.settings.menu.links -%}
              <li class="wm-main-menu__item">
                <a href="{{ link.url }}" class="wm-main-menu__link{% if link.current %} is-active{% endif %}">
                  {{ link.title | escape }}
                </a>
              </li>
            {%- else -%}
              {%- assign default_nav = 'Home|Collections|New Arrivals|Best Sellers|About Us|Contact' | split: '|' -%}
              {%- for item in default_nav -%}
                <li class="wm-main-menu__item">
                  <a href="/collections/all" class="wm-main-menu__link">
                    {{ item }}
                  </a>
                </li>
              {%- endfor -%}
            {%- endfor -%}
          </ul>
        </nav>

        {%- comment -%} Right Actions Area {%- endcomment -%}
        <div class="wm-header__actions">
          <div class="wm-header__selectors">
            <span class="wm-selector">USA ▾</span>
            <span class="wm-selector">USD ▾</span>
          </div>

          {%- if shop.customer_accounts_enabled -%}
            <a href="{{ routes.account_url }}" class="wm-action-btn" aria-label="Account">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </a>
          {%- else -%}
            <a href="/account/login" class="wm-action-btn" aria-label="Account">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </a>
          {%- endif -%}

          <a href="#" class="wm-action-btn wm-action-btn--badge" aria-label="Compare">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
            <span class="wm-action-badge">0</span>
          </a>

          <a href="/pages/wishlist" class="wm-action-btn wm-action-btn--badge" aria-label="Wishlist">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l8.72-8.72 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            <span class="wm-action-badge">0</span>
          </a>

          {%- comment -%} Cart Pill Button with Live Total {%- endcomment -%}
          <a href="{{ routes.cart_url }}" class="wm-cart-btn">
            <span class="wm-cart-btn__icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
              <span class="wm-cart-btn__badge">{{ cart.item_count }}</span>
            </span>
            <span class="wm-cart-btn__price">{{ cart.total_price | money }}</span>
          </a>
        </div>

      </div>
    </div>

  </div>

  {%- comment -%} ════ MOBILE HEADER (MAX-WIDTH: 989PX) ════ {%- endcomment -%}
  <div class="wm-header__mobile large-up-hide">
    {%- comment -%} Mobile Row 1: Hamburger | Logo | Account {%- endcomment -%}
    <div class="wm-mobile-top">
      <button type="button" class="wm-mobile-toggle" onclick="openWmMobileDrawer()" aria-label="Open navigation menu">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>

      <div class="wm-mobile-logo">
        <a href="{{ routes.root_url }}">
          {%- if settings.logo != blank -%}
            {{ settings.logo | image_url: width: 300 | image_tag: class: 'wm-mobile-logo-img', alt: shop.name }}
          {%- else -%}
            <span class="wm-header__logo-text">{{ section.settings.logo_text | default: shop.name }}<span>.</span></span>
          {%- endif -%}
        </a>
      </div>

      <a href="{{ routes.account_url }}" class="wm-mobile-account" aria-label="Account">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
    </div>

    {%- comment -%} Mobile Row 2: Full Width Search Pill {%- endcomment -%}
    <div class="wm-mobile-search-row">
      <form action="{{ routes.search_url }}" method="get" role="search" class="wm-header__search-form">
        <input
          type="search"
          name="q"
          class="wm-header__search-input"
          placeholder="{{ section.settings.search_placeholder | default: 'Search for products...' }}"
          aria-label="Search for products"
          autocomplete="off"
        >
        <button type="submit" class="wm-header__search-btn" aria-label="Search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>
      </form>
    </div>
  </div>

</header>

<style>
/* ════════════════════════════════════════════════════════════
   FOESTA BRAND DUAL-ROW HEADER SYSTEM (LARGE TYPOGRAPHY)
   ════════════════════════════════════════════════════════════ */
.wm-header {
  position: relative;
  background: #FFFFFF;
  border-bottom: 1px solid #E5E8F0;
  font-family: var(--font-body);
}

/* TOP ROW */
.wm-header__top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 18px;
  padding-bottom: 18px;
  gap: 2.5rem;
}

.wm-header__logo-text {
  font-family: var(--font-heading);
  font-size: 2.25rem;
  font-weight: 800;
  letter-spacing: -0.03em;
  color: #121316;
}

.wm-header__logo-text span {
  color: var(--color-accent-gold, #C9A96E);
}

.wm-header__logo-img {
  max-height: 48px;
  width: auto;
}

/* SEARCH CONTAINER */
.wm-header__search-container {
  flex: 1;
  max-width: 680px;
}

.wm-header__search-form {
  position: relative;
  display: flex;
  align-items: center;
  width: 100%;
}

.wm-header__search-input {
  width: 100%;
  height: 52px;
  padding: 0 60px 0 24px;
  border-radius: var(--radius-pill);
  border: 1.5px solid #E5E8F0;
  background: #FFFFFF;
  font-family: var(--font-body);
  font-size: 1rem;
  font-weight: 500;
  color: #121316;
  outline: none;
  transition: all 250ms ease;
  box-shadow: 0 4px 14px rgba(18, 19, 22, 0.03);
}

.wm-header__search-input:focus {
  border-color: #121316;
  box-shadow: 0 0 0 4px rgba(18, 19, 22, 0.08);
}

.wm-header__search-input::placeholder {
  color: #8E95A2;
}

.wm-header__search-btn {
  position: absolute;
  right: 6px;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: none;
  background: #121316;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: transform 250ms cubic-bezier(0.34, 1.56, 0.64, 1), background 200ms ease;
}

.wm-header__search-btn:hover {
  background: var(--color-accent-gold, #C9A96E);
  transform: scale(1.06);
}

/* SUPPORT BADGES */
.wm-header__support-badges {
  display: flex;
  align-items: center;
  gap: 2.25rem;
}

.wm-support-badge {
  display: flex;
  align-items: center;
  gap: 12px;
}

.wm-support-badge__icon {
  color: #121316;
  display: flex;
  align-items: center;
}

.wm-support-badge__info {
  display: flex;
  flex-direction: column;
}

.wm-support-badge__title {
  font-size: 0.875rem;
  font-weight: 800;
  color: #121316;
  line-height: 1.25;
}

.wm-support-badge__value {
  font-size: 0.875rem;
  font-weight: 600;
  color: #555B68;
}

.wm-support-badge__value--accent {
  color: var(--color-accent-gold, #C9A96E);
  font-weight: 700;
}

/* BOTTOM NAVIGATION ROW (FOESTA SOFT PASTEL TINT) */
.wm-header__bottom-bar {
  background: #F8F9FD;
  border-top: 1px solid #E5E8F0;
  border-bottom: 1px solid #E5E8F0;
}

.wm-header__nav-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 56px;
}

/* CATEGORIES DROPDOWN BUTTON */
.wm-categories-dropdown {
  position: relative;
}

.wm-categories-btn {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 6px 20px 6px 6px;
  background: #FFFFFF;
  border: 1.5px solid #E5E8F0;
  border-radius: var(--radius-pill);
  font-family: var(--font-body);
  font-size: 0.9375rem;
  font-weight: 800;
  color: #121316;
  cursor: pointer;
  box-shadow: 0 4px 14px rgba(18, 19, 22, 0.04);
  transition: all 250ms ease;
}

.wm-categories-btn:hover {
  border-color: #121316;
  box-shadow: 0 6px 18px rgba(18, 19, 22, 0.08);
}

.wm-categories-btn__icon-bg {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: #121316;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 200ms ease;
}

.wm-categories-btn:hover .wm-categories-btn__icon-bg {
  background: var(--color-accent-gold, #C9A96E);
}

/* CATEGORIES PANEL */
.wm-categories-panel {
  position: absolute;
  top: calc(100% + 8px);
  left: 0;
  width: 280px;
  background: #FFFFFF;
  border: 1px solid #E5E8F0;
  border-radius: 18px;
  box-shadow: 0 20px 48px rgba(18, 19, 22, 0.12);
  opacity: 0;
  visibility: hidden;
  transform: translateY(10px);
  transition: all 250ms ease;
  z-index: 200;
}

.wm-categories-dropdown:hover .wm-categories-panel {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.wm-categories-list {
  list-style: none;
  padding: 10px 0;
  margin: 0;
}

.wm-categories-item {
  border-bottom: 1px solid #F0F2F7;
}

.wm-categories-item:last-child {
  border-bottom: none;
}

.wm-categories-link {
  display: flex;
  align-items: center;
  padding: 12px 18px;
  font-size: 0.9375rem;
  font-weight: 700;
  color: #121316;
  text-decoration: none;
  transition: background 150ms ease, color 150ms ease;
}

.wm-categories-link:hover {
  background: #F4F5FE;
  color: var(--color-accent-gold, #C9A96E);
}

.wm-categories-link__icon {
  margin-right: 12px;
  color: #555B68;
  display: flex;
  align-items: center;
}

.wm-categories-link__title {
  flex: 1;
}

.wm-categories-arrow {
  color: #8E95A2;
}

/* MAIN NAV MENU — ULTRA-MODERN FOESTA CAPSULE BAR */
.wm-header__main-nav {
  display: flex;
  align-items: center;
}

.wm-main-menu {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  list-style: none;
  padding: 4px 6px;
  margin: 0;
  background: rgba(255, 255, 255, 0.75);
  border: 1px solid rgba(229, 232, 240, 0.9);
  border-radius: var(--radius-pill);
  box-shadow: 0 2px 10px rgba(18, 19, 22, 0.03);
}

.wm-main-menu__item {
  position: relative;
}

.wm-main-menu__link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-body);
  font-size: 0.9375rem;
  font-weight: 700;
  letter-spacing: 0.01em;
  color: #121316;
  text-decoration: none;
  padding: 8px 18px;
  border-radius: var(--radius-pill);
  transition: all 250ms cubic-bezier(0.25, 1, 0.5, 1);
  position: relative;
}

.wm-main-menu__link:hover {
  background: #121316;
  color: #FFFFFF;
  transform: translateY(-1px);
  box-shadow: 0 4px 14px rgba(18, 19, 22, 0.15);
}

.wm-main-menu__link.is-active {
  background: #121316;
  color: #FFFFFF;
  font-weight: 800;
  box-shadow: 0 4px 14px rgba(18, 19, 22, 0.18);
}

.wm-main-menu__link.is-active::after {
  content: '';
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--color-accent-gold, #C9A96E);
  display: inline-block;
  margin-left: 2px;
}

/* ACTIONS AREA */
.wm-header__actions {
  display: flex;
  align-items: center;
  gap: 1.25rem;
}

.wm-header__selectors {
  display: flex;
  align-items: center;
  gap: 0.85rem;
  font-size: 0.875rem;
  font-weight: 700;
  color: #121316;
}

.wm-selector {
  cursor: pointer;
}

.wm-action-btn {
  position: relative;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #FFFFFF;
  border: 1.5px solid #E5E8F0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #121316;
  text-decoration: none;
  transition: all 250ms ease;
}

.wm-action-btn:hover {
  border-color: #121316;
  background: #121316;
  color: #FFFFFF;
  transform: translateY(-2px);
}

.wm-action-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  background: #FF4D4D;
  color: #FFFFFF;
  font-size: 0.6875rem;
  font-weight: 800;
  min-width: 18px;
  height: 18px;
  border-radius: 50%;
  border: 2px solid #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* CART PILL BUTTON WITH LIVE TOTAL */
.wm-cart-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  font-family: var(--font-body);
  font-size: 0.9375rem;
  font-weight: 800;
  color: #121316;
  transition: transform 200ms ease;
}

.wm-cart-btn:hover {
  transform: translateY(-1px);
}

.wm-cart-btn__icon {
  position: relative;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #121316;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 200ms ease;
}

.wm-cart-btn:hover .wm-cart-btn__icon {
  background: var(--color-accent-gold, #C9A96E);
}

.wm-cart-btn__badge {
  position: absolute;
  top: -3px;
  right: -3px;
  background: #FF4D4D;
  color: #FFFFFF;
  font-size: 0.6875rem;
  font-weight: 800;
  min-width: 18px;
  height: 18px;
  border-radius: 50%;
  border: 2px solid #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* MOBILE STYLES */
.wm-header__mobile {
  padding: 14px 18px;
}

.wm-mobile-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14px;
}

.wm-mobile-toggle, .wm-mobile-account {
  background: transparent;
  border: none;
  color: #121316;
  padding: 0;
  cursor: pointer;
}

.wm-mobile-logo-img {
  max-height: 40px;
  width: auto;
}

.wm-mobile-search-row {
  width: 100%;
}
</style>

{% schema %}
{
  "name": "Header",
  "tag": "header",
  "class": "section-header",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Brand Logo Text",
      "default": "foesta"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search Placeholder Text",
      "default": "Search for products..."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main Pages Menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "categories_menu",
      "label": "All Categories Menu"
    },
    {
      "type": "header",
      "content": "Support Info Badges"
    },
    {
      "type": "text",
      "id": "support_phone",
      "label": "Phone Number",
      "default": "+1 (800) 123-4567"
    },
    {
      "type": "text",
      "id": "shipping_text",
      "label": "Shipping Text",
      "default": "Free Shipping"
    }
  ]
}
{% endschema %}
