{%- comment -%}
  Section: Modern Email Signup Banner (Foesta Edition)
  Sleek pill-capsule newsletter section with card container, gradient text,
  and instant discount perk badges.
{%- endcomment -%}

{%- style -%}
#section-{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  {%- if section.settings.bg_preset == 'page_bg' -%}
    background: transparent;
  {%- elsif section.settings.bg_preset == 'soft_tint' -%}
    background: #F8F9FD;
  {%- elsif section.settings.bg_preset == 'dark' -%}
    background: #121316;
  {%- else -%}
    background: transparent;
  {%- endif -%}
}

.ds-newsletter-v2__card {
  max-width: 800px;
  margin: 0 auto;
  padding: 3.5rem 2.5rem;
  border-radius: 28px;
  text-align: center;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.25rem;
  transition: transform 300ms ease, box-shadow 300ms ease;

  {%- if section.settings.card_style == 'gradient' -%}
    background: linear-gradient(135deg, #FFFFFF 0%, #F4F5FE 50%, #EAEBFB 100%);
    border: 1px solid #E5E8F0;
    box-shadow: 0 16px 40px rgba(18, 19, 22, 0.06);
  {%- elsif section.settings.card_style == 'dark' -%}
    background: linear-gradient(135deg, #1C1D22 0%, #121316 100%);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
    color: #FFFFFF;
  {%- elsif section.settings.card_style == 'glass' -%}
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(229, 232, 240, 0.9);
    box-shadow: 0 16px 40px rgba(18, 19, 22, 0.05);
  {%- else -%}
    background: transparent;
  {%- endif -%}
}

/* Floating Icon Badge */
.ds-newsletter-v2__icon-badge {
  width: 58px;
  height: 58px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 0.25rem;
  transition: transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1);

  {%- if section.settings.card_style == 'dark' -%}
    background: rgba(255, 255, 255, 0.1);
    color: var(--color-accent-gold, #C9A96E);
    border: 1px solid rgba(255, 255, 255, 0.15);
  {%- else -%}
    background: #121316;
    color: #FFFFFF;
    box-shadow: 0 8px 24px rgba(18, 19, 22, 0.15);
  {%- endif -%}
}

.ds-newsletter-v2__card:hover .ds-newsletter-v2__icon-badge {
  transform: scale(1.1) rotate(-6deg);
}

.ds-newsletter-v2__icon-badge svg {
  width: 24px;
  height: 24px;
}

/* Eyebrow Tag */
.ds-newsletter-v2__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 5px 14px;
  border-radius: var(--radius-pill);
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 800;
  letter-spacing: 0.2em;
  text-transform: uppercase;

  {%- if section.settings.card_style == 'dark' -%}
    background: rgba(201, 169, 110, 0.15);
    color: var(--color-accent-gold, #C9A96E);
    border: 1px solid rgba(201, 169, 110, 0.3);
  {%- else -%}
    background: #EAEBFB;
    color: #121316;
  {%- endif -%}
}

/* Heading & Subheading */
.ds-newsletter-v2__heading {
  font-family: var(--font-heading);
  font-size: clamp(1.75rem, 4vw, 2.75rem);
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1.2;
  margin: 0;
  {%- if section.settings.card_style == 'dark' -%}
    color: #FFFFFF;
  {%- else -%}
    color: #121316;
  {%- endif -%}
}

.ds-newsletter-v2__heading span {
  background: linear-gradient(135deg, #FF4D4D 0%, #C9A96E 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.ds-newsletter-v2__subheading {
  font-family: var(--font-body);
  font-size: clamp(0.9375rem, 1.5vw, 1.0625rem);
  font-weight: 400;
  line-height: 1.6;
  max-width: 540px;
  margin: 0;
  {%- if section.settings.card_style == 'dark' -%}
    color: rgba(255, 255, 255, 0.75);
  {%- else -%}
    color: #555B68;
  {%- endif -%}
}

/* Unified Pill Input Form Container */
.ds-newsletter-v2__form-wrapper {
  width: 100%;
  max-width: 520px;
  margin-top: 0.5rem;
}

.ds-newsletter-v2__pill-group {
  position: relative;
  display: flex;
  align-items: center;
  border-radius: var(--radius-pill);
  padding: 6px 6px 6px 20px;
  transition: all 300ms ease;

  {%- if section.settings.card_style == 'dark' -%}
    background: rgba(255, 255, 255, 0.08);
    border: 1.5px solid rgba(255, 255, 255, 0.18);
  {%- else -%}
    background: #FFFFFF;
    border: 1.5px solid #E5E8F0;
    box-shadow: 0 8px 30px rgba(18, 19, 22, 0.08);
  {%- endif -%}
}

.ds-newsletter-v2__pill-group:focus-within {
  {%- if section.settings.card_style == 'dark' -%}
    border-color: var(--color-accent-gold, #C9A96E);
    box-shadow: 0 0 0 4px rgba(201, 169, 110, 0.2);
  {%- else -%}
    border-color: #121316;
    box-shadow: 0 12px 36px rgba(18, 19, 22, 0.14);
  {%- endif -%}
}

.ds-newsletter-v2__input-icon {
  width: 20px;
  height: 20px;
  flex-shrink: 0;
  margin-right: 12px;
  opacity: 0.45;
  {%- if section.settings.card_style == 'dark' -%}
    color: #FFFFFF;
  {%- else -%}
    color: #121316;
  {%- endif -%}
}

.ds-newsletter-v2__input {
  flex: 1;
  border: none !important;
  background: transparent !important;
  outline: none !important;
  font-family: var(--font-body);
  font-size: 0.9375rem;
  font-weight: 500;
  padding: 10px 0;
  width: 100%;
  {%- if section.settings.card_style == 'dark' -%}
    color: #FFFFFF;
  {%- else -%}
    color: #121316;
  {%- endif -%}
}

.ds-newsletter-v2__input::placeholder {
  {%- if section.settings.card_style == 'dark' -%}
    color: rgba(255, 255, 255, 0.45);
  {%- else -%}
    color: #8E95A2;
  {%- endif -%}
}

.ds-newsletter-v2__submit-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 0.85rem 1.85rem;
  border-radius: var(--radius-pill);
  font-family: var(--font-body);
  font-size: 0.9375rem;
  font-weight: 700;
  letter-spacing: 0.02em;
  border: none;
  cursor: pointer;
  flex-shrink: 0;
  transition: all 300ms cubic-bezier(0.34, 1.56, 0.64, 1);

  {%- if section.settings.card_style == 'dark' -%}
    background: #FFFFFF;
    color: #121316;
  {%- else -%}
    background: #121316;
    color: #FFFFFF;
  {%- endif -%}
}

.ds-newsletter-v2__submit-btn:hover {
  {%- if section.settings.card_style == 'dark' -%}
    background: var(--color-accent-gold, #C9A96E);
    color: #FFFFFF;
    transform: scale(1.04);
  {%- else -%}
    background: var(--color-accent-gold, #C9A96E);
    color: #FFFFFF;
    transform: scale(1.04);
  {%- endif -%}
  box-shadow: 0 8px 20px rgba(201, 169, 110, 0.3);
}

.ds-newsletter-v2__submit-btn svg {
  transition: transform 300ms ease;
}

.ds-newsletter-v2__submit-btn:hover svg {
  transform: translateX(4px);
}

/* Success & Error State */
.ds-newsletter-v2__success {
  background: var(--color-success-bg, #ECFDF5);
  border: 1px solid var(--color-success, #10B981);
  color: var(--color-success, #10B981);
  padding: 1rem 1.5rem;
  border-radius: 16px;
  font-family: var(--font-body);
  font-size: 0.9375rem;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
}

/* Perks Strip */
.ds-newsletter-v2__perks {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.25rem;
  flex-wrap: wrap;
  margin-top: 0.5rem;
  font-size: 0.75rem;
  font-weight: 600;
  {%- if section.settings.card_style == 'dark' -%}
    color: rgba(255, 255, 255, 0.6);
  {%- else -%}
    color: #8E95A2;
  {%- endif -%}
}

.ds-newsletter-v2__perk-item {
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

@media (max-width: 639px) {
  .ds-newsletter-v2__card {
    padding: 2.5rem 1.25rem;
    border-radius: 20px;
  }
  .ds-newsletter-v2__pill-group {
    flex-direction: column;
    padding: 10px;
    border-radius: 20px;
    gap: 8px;
  }
  .ds-newsletter-v2__input-icon {
    display: none;
  }
  .ds-newsletter-v2__input {
    text-align: center;
    padding: 8px 0;
  }
  .ds-newsletter-v2__submit-btn {
    width: 100%;
  }
}
{%- endstyle -%}

<section class="ds-newsletter-v2" id="section-{{ section.id }}">
  <div class="ds-container">
    <div class="ds-newsletter-v2__card">
      <div class="ds-newsletter-v2__icon-badge" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </div>

      {%- if section.settings.eyebrow != blank -%}
        <span class="ds-newsletter-v2__eyebrow">
          <span>✦</span> {{ section.settings.eyebrow | escape }} <span>✦</span>
        </span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="ds-newsletter-v2__heading">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="ds-newsletter-v2__subheading">
          {{ section.settings.subheading | escape }}
        </p>
      {%- endif -%}

      <div class="ds-newsletter-v2__form-wrapper">
        {%- form 'customer', class: 'ds-newsletter-v2__form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">

          {%- if form.posted_successfully? -%}
            <div class="ds-newsletter-v2__success" role="alert">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              <span>🎉 Thank you! Check your inbox for your 10% discount code.</span>
            </div>
          {%- else -%}
            {%- if form.errors -%}
              <p class="ds-form-error" style="color: #FF4D4D; margin-bottom: 8px; font-size: 13px;">
                {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
              </p>
            {%- endif -%}

            <div class="ds-newsletter-v2__pill-group">
              <svg class="ds-newsletter-v2__input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <input
                type="email"
                name="contact[email]"
                class="ds-newsletter-v2__input"
                value="{{ form.email }}"
                placeholder="{{ section.settings.placeholder_text | default: 'Enter your email address...' }}"
                aria-label="Email address"
                required
                autocorrect="off"
                autocapitalize="off"
              >
              <button
                type="submit"
                class="ds-newsletter-v2__submit-btn"
                name="commit"
              >
                <span>{{ section.settings.button_label | default: 'Subscribe' }}</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </button>
            </div>
          {%- endif -%}
        {%- endform -%}
      </div>

      <div class="ds-newsletter-v2__perks">
        <span class="ds-newsletter-v2__perk-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          Instant 10% Off Code
        </span>
        <span>•</span>
        <span class="ds-newsletter-v2__perk-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          No Spam Guarantee
        </span>
        <span>•</span>
        <span class="ds-newsletter-v2__perk-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          VIP Drop Access
        </span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Email Signup Banner",
  "tag": "section",
  "class": "section-email-signup-banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "JOIN THE CLUB"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading (supports HTML <span> for gradient)",
      "default": "Get <span>10% Off</span> Your First Order"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Subscribe to receive exclusive deals, new collection drops, and insider style tips."
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Input placeholder",
      "default": "Enter your email address..."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Card Style",
      "options": [
        { "value": "gradient", "label": "Soft Pastel Gradient (Foesta)" },
        { "value": "dark", "label": "Luxury Dark Charcoal" },
        { "value": "glass", "label": "Glassmorphism Card" },
        { "value": "minimal", "label": "Minimal Clean Canvas" }
      ],
      "default": "gradient"
    },
    {
      "type": "select",
      "id": "bg_preset",
      "label": "Section Background",
      "options": [
        { "value": "page_bg", "label": "Transparent Canvas" },
        { "value": "soft_tint", "label": "Soft Light Tint (#F8F9FD)" },
        { "value": "dark", "label": "Dark Section Background (#121316)" }
      ],
      "default": "page_bg"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Email Signup Banner"
    }
  ]
}
{% endschema %}
