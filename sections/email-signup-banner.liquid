{%- comment -%}
  Section: Email Signup Banner (Newsletter)
  Warm gold-tinted box with headline, discount offer, email input form,
  and spam protection guarantee.
{%- endcomment -%}

<section class="ds-section ds-section--accent-bg ds-newsletter" id="section-{{ section.id }}">
  <div class="ds-container">
    <div class="ds-newsletter__card" data-animate>
      <div class="ds-newsletter__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </div>

      {%- if section.settings.eyebrow != blank -%}
        <span class="ds-newsletter__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="ds-newsletter__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="ds-newsletter__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <div class="ds-newsletter__form-wrapper">
        {%- form 'customer', class: 'ds-newsletter__form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          {%- if form.posted_successfully? -%}
            <div class="ds-newsletter__success" role="alert">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              <span>🎉 Thank you! Check your inbox for your 10% discount code.</span>
            </div>
          {%- else -%}
            {%- if form.errors -%}
              <p class="ds-form-error">{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</p>
            {%- endif -%}

            <div class="ds-newsletter__input-group">
              <input
                type="email"
                name="contact[email]"
                class="ds-input ds-newsletter__input"
                value="{{ form.email }}"
                placeholder="{{ section.settings.placeholder_text | default: 'Enter your email address...' }}"
                aria-label="Email address"
                required
                autocorrect="off"
                autocapitalize="off"
              >
              <button
                type="submit"
                class="ds-btn ds-btn--primary ds-newsletter__btn"
                name="commit"
              >
                <span>{{ section.settings.button_label | default: 'Subscribe' }}</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </button>
            </div>
          {%- endif -%}
        {%- endform -%}
      </div>

      <p class="ds-newsletter__disclaimer">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        We respect your privacy. No spam, unsubscribe at any time.
      </p>
    </div>
  </div>
</section>

<style>
/* ═══ NEWSLETTER ═══ */
.ds-newsletter {
  border-top: 1px solid var(--color-accent-light);
  border-bottom: 1px solid var(--color-accent-light);
}

.ds-newsletter__card {
  max-width: 680px;
  margin: 0 auto;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-4) 0;
}

.ds-newsletter__icon {
  width: 44px;
  height: 44px;
  color: var(--color-accent);
  margin-bottom: var(--space-1);
}

.ds-newsletter__icon svg {
  width: 100%;
  height: 100%;
}

.ds-newsletter__eyebrow {
  font-family: var(--font-body);
  font-size: var(--font-size-3xs);
  font-weight: var(--weight-semibold);
  letter-spacing: var(--tracking-widest);
  text-transform: uppercase;
  color: var(--color-accent-dark);
}

.ds-newsletter__heading {
  font-family: var(--font-heading);
  font-size: var(--font-size-h2);
  font-weight: var(--weight-bold);
  color: var(--color-text-primary);
  margin: 0;
  line-height: var(--line-height-heading);
}

.ds-newsletter__subheading {
  font-family: var(--font-body);
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  line-height: var(--line-height-relaxed);
  margin: 0 0 var(--space-4);
  max-width: 520px;
}

.ds-newsletter__form-wrapper {
  width: 100%;
  max-width: 500px;
}

.ds-newsletter__form {
  width: 100%;
}

.ds-newsletter__input-group {
  display: flex;
  gap: var(--space-3);
  width: 100%;
}

.ds-newsletter__input {
  flex: 1;
  border-color: var(--color-accent-light);
  background: #FFFFFF;
}

.ds-newsletter__input:focus {
  border-color: var(--color-accent);
}

.ds-newsletter__btn {
  flex-shrink: 0;
}

.ds-newsletter__success {
  background: var(--color-success-bg);
  border: 1px solid var(--color-success);
  color: var(--color-success);
  padding: var(--space-4) var(--space-6);
  border-radius: var(--radius-sm);
  font-family: var(--font-body);
  font-size: var(--font-size-sm);
  font-weight: var(--weight-medium);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-3);
}

.ds-newsletter__disclaimer {
  font-family: var(--font-body);
  font-size: var(--font-size-3xs);
  color: var(--color-text-muted);
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-top: var(--space-3);
}

@media (max-width: 639px) {
  .ds-newsletter__input-group {
    flex-direction: column;
  }
  .ds-newsletter__btn {
    width: 100%;
  }
}
</style>

{% schema %}
{
  "name": "Email Signup Banner",
  "tag": "section",
  "class": "section-email-signup-banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Join the Family"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get 10% Off Your First Order"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Subscribe to receive exclusive deals, new collection drops, and insider style tips."
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Input placeholder",
      "default": "Enter your email address..."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button text",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "Email Signup Banner"
    }
  ]
}
{% endschema %}
