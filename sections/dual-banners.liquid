{%- comment -%}
  Section: Dual Promo Banners — Glassmorphism Edition
  Layout: Full-bleed image cards with frosted glass content panel at bottom
  Feel: Apple, Shopify, Framer — modern, premium, tactile
{%- endcomment -%}

<section class="ds-glass-section ds-section" id="section-{{ section.id }}">
  <div class="ds-container">
    <div class="ds-glass-grid">

      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- assign img_idx = forloop.index0 | modulo: 2 -%}
          {%- assign fb1 = 'https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=900&auto=format&fit=crop&q=85' -%}
          {%- assign fb2 = 'https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=900&auto=format&fit=crop&q=85' -%}
          {%- if img_idx == 0 -%}{%- assign fbimg = fb1 -%}{%- else -%}{%- assign fbimg = fb2 -%}{%- endif -%}

          <div class="ds-glass-card" {{ block.shopify_attributes }}>
            {%- comment -%} Background image {%- endcomment -%}
            <div class="ds-glass-card__bg">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 900 }}" class="ds-glass-card__img" loading="lazy" alt="{{ block.settings.title | default: 'Promo' | escape }}">
              {%- else -%}
                <img src="{{ fbimg }}" class="ds-glass-card__img" loading="lazy" alt="{{ block.settings.title | default: 'Promo' | escape }}">
              {%- endif -%}
            </div>

            {%- comment -%} Top-left badge {%- endcomment -%}
            {%- if block.settings.eyebrow != blank -%}
              <span class="ds-glass-card__badge">{{ block.settings.eyebrow }}</span>
            {%- endif -%}

            {%- comment -%} Frosted glass panel at bottom {%- endcomment -%}
            <div class="ds-glass-card__panel">
              {%- if block.settings.title != blank -%}
                <h3 class="ds-glass-card__heading">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="ds-glass-card__body">{{ block.settings.description }}</p>
              {%- endif -%}
              {%- if block.settings.button_label != blank -%}
                <a href="{{ block.settings.button_url | default: '/collections/all' }}" class="ds-glass-card__cta">
                  <span>{{ block.settings.button_label }}</span>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}

      {%- else -%}

        <div class="ds-glass-card">
          <div class="ds-glass-card__bg">
            <img src="https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=900&auto=format&fit=crop&q=85" class="ds-glass-card__img" loading="lazy" alt="Fashion Collection">
          </div>
          <span class="ds-glass-card__badge">New Season</span>
          <div class="ds-glass-card__panel">
            <h3 class="ds-glass-card__heading">Fresh Styles,<br>Fresh Confidence.</h3>
            <p class="ds-glass-card__body">Discover our latest fashion drops &mdash; thoughtfully curated pieces that make every outfit effortless.</p>
            <a href="/collections/all" class="ds-glass-card__cta">
              <span>Shop Fashion</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>

        <div class="ds-glass-card">
          <div class="ds-glass-card__bg">
            <img src="https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=900&auto=format&fit=crop&q=85" class="ds-glass-card__img" loading="lazy" alt="Home Decor">
          </div>
          <span class="ds-glass-card__badge">Home &amp; Living</span>
          <div class="ds-glass-card__panel">
            <h3 class="ds-glass-card__heading">Elevate Every<br>Corner of Your Home.</h3>
            <p class="ds-glass-card__body">Premium home decor pieces that transform your space into a sanctuary of style and calm.</p>
            <a href="/collections/all" class="ds-glass-card__cta">
              <span>Shop Decor</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>

      {%- endif -%}
    </div>
  </div>
</section>

<style>
/* ═══════════════════════════════════════════════
   DUAL BANNERS — GLASSMORPHISM EDITION
   Feel: Apple · Framer · Shopify
   ═══════════════════════════════════════════════ */
.ds-glass-section {
  background: #F5F4F2;
  padding: 5rem 0;
}

.ds-glass-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}

/* ━━ CARD ━━ */
.ds-glass-card {
  position: relative;
  border-radius: 24px;
  overflow: hidden;
  min-height: 480px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 1.5rem;
  cursor: pointer;
}

/* ━━ FULL-BLEED BACKGROUND IMAGE ━━ */
.ds-glass-card__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.ds-glass-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
}

.ds-glass-card:hover .ds-glass-card__img {
  transform: scale(1.06);
}

/* Dark gradient for readability */
.ds-glass-card::before {
  content: '';
  position: absolute;
  inset: 0;
  z-index: 1;
  background: linear-gradient(
    to top,
    rgba(10, 10, 15, 0.75) 0%,
    rgba(10, 10, 15, 0.25) 55%,
    rgba(10, 10, 15, 0.05) 100%
  );
  transition: background 350ms ease;
}

.ds-glass-card:hover::before {
  background: linear-gradient(
    to top,
    rgba(10, 10, 15, 0.82) 0%,
    rgba(10, 10, 15, 0.32) 55%,
    rgba(10, 10, 15, 0.08) 100%
  );
}

/* ━━ TOP-LEFT BADGE ━━ */
.ds-glass-card__badge {
  position: absolute;
  top: 1.25rem;
  left: 1.25rem;
  z-index: 3;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.35);
  color: #FFFFFF;
  font-family: var(--font-body);
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  padding: 0.4rem 0.9rem;
  border-radius: 100px;
}

/* ━━ FROSTED GLASS PANEL ━━ */
.ds-glass-card__panel {
  position: relative;
  z-index: 2;
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.22);
  border-radius: 16px;
  padding: 1.5rem 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  transition: background 350ms ease, transform 350ms cubic-bezier(0.16, 1, 0.3, 1);
}

.ds-glass-card:hover .ds-glass-card__panel {
  background: rgba(255, 255, 255, 0.18);
  transform: translateY(-4px);
}

.ds-glass-card__heading {
  font-family: var(--font-heading);
  font-size: clamp(1.5rem, 2.2vw, 2rem);
  font-weight: 900;
  color: #FFFFFF;
  margin: 0;
  line-height: 1.2;
  letter-spacing: -0.02em;
  text-shadow: 0 2px 12px rgba(0,0,0,0.3);
}

.ds-glass-card__body {
  font-family: var(--font-body);
  font-size: 0.9rem;
  color: rgba(255, 255, 255, 0.82);
  line-height: 1.6;
  margin: 0;
}

/* CTA pill button */
.ds-glass-card__cta {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  align-self: flex-start;
  background: #FFFFFF;
  color: #121316;
  font-family: var(--font-body);
  font-size: 0.88rem;
  font-weight: 800;
  padding: 0.65rem 1.35rem;
  border-radius: 100px;
  text-decoration: none;
  transition: background 250ms ease, color 250ms ease, gap 250ms ease, box-shadow 250ms ease;
  box-shadow: 0 4px 16px rgba(0,0,0,0.2);
}

.ds-glass-card__cta:hover {
  background: var(--accent-orange, #E05A2B);
  color: #FFFFFF;
  box-shadow: 0 6px 24px rgba(224, 90, 43, 0.45);
  gap: 0.75rem;
}

.ds-glass-card__cta svg {
  transition: transform 250ms ease;
  flex-shrink: 0;
}

.ds-glass-card__cta:hover svg {
  transform: translateX(3px);
}

/* ━━ RESPONSIVE ━━ */
@media (max-width: 1024px) {
  .ds-glass-card { min-height: 420px; }
}

@media (max-width: 767px) {
  .ds-glass-section { padding: 3rem 0; }
  .ds-glass-grid { grid-template-columns: 1fr; gap: 1rem; }
  .ds-glass-card { min-height: 380px; padding: 1.25rem; border-radius: 18px; }
  .ds-glass-card__heading { font-size: 1.5rem; }
  .ds-glass-card__body { font-size: 0.85rem; }
}
</style>

{% schema %}
{
  "name": "Dual Promo Banners",
  "tag": "section",
  "class": "section-dual-banners",
  "settings": [],
  "blocks": [
    {
      "type": "banner",
      "name": "Promo Banner",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow Label", "default": "New Arrival" },
        { "type": "text", "id": "title", "label": "Heading", "default": "Wear Your Faith Daily." },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Spiritual t-shirts crafted with intention and care." },
        { "type": "text", "id": "button_label", "label": "Button Label", "default": "Shop Collection" },
        { "type": "url", "id": "button_url", "label": "Button URL" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "presets": [{ "name": "Dual Promo Banners" }]
}
{% endschema %}
