{%- comment -%}
  Section: Trust Bar (Redesigned Next-Gen Luxury Edition)
  4 interactive floating cards with glowing icon badges, high-contrast typography,
  and smooth hover elevation.
{%- endcomment -%}

<section class="ds-trust-next" id="section-{{ section.id }}">
  <div class="ds-container">
    <div class="ds-trust-next__grid">

      {%- for block in section.blocks -%}
        <div class="ds-trust-card-next" {{ block.shopify_attributes }}>
          <div class="ds-trust-card-next__icon-wrap" aria-hidden="true">
            {%- case forloop.index -%}
              {%- when 1 -%}
                {%- comment -%} Shipping truck {%- endcomment -%}
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                </svg>
              {%- when 2 -%}
                {%- comment -%} Credit card / Secured payment {%- endcomment -%}
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>
                </svg>
              {%- when 3 -%}
                {%- comment -%} Returns / refresh {%- endcomment -%}
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.5"/>
                </svg>
              {%- when 4 -%}
                {%- comment -%} Surprise gift {%- endcomment -%}
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
                </svg>
              {%- else -%}
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
            {%- endcase -%}
          </div>

          <div class="ds-trust-card-next__text">
            <h4 class="ds-trust-card-next__title">{{ block.settings.title }}</h4>
            <p class="ds-trust-card-next__subtitle">{{ block.settings.subtitle }}</p>
          </div>
        </div>
      {%- else -%}
        {%- assign titles = 'Worldwide Shipping,Secured Payment,30 Days Free Returns,Surprise Gift' | split: ',' -%}
        {%- assign subs = 'World Wide Free Shipping,Safe & Secured Payments,Within 30 Days For Exchange,Free gift worth for customers' | split: ',' -%}
        {%- for t in titles -%}
          <div class="ds-trust-card-next">
            <div class="ds-trust-card-next__icon-wrap" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            </div>
            <div class="ds-trust-card-next__text">
              <h4 class="ds-trust-card-next__title">{{ t }}</h4>
              <p class="ds-trust-card-next__subtitle">{{ subs[forloop.index0] }}</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}

    </div>
  </div>
</section>

<style>
/* ═════════════════════════════════════════════
   TRUST BAR (NEXT-GEN MODERN EDITION)
   ═════════════════════════════════════════════ */
.ds-trust-next {
  padding: 3.5rem 0 2rem;
  background: #FFFFFF;
}

.ds-trust-next__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-5);
}

.ds-trust-card-next {
  background: #FFFFFF;
  border-radius: 16px;
  padding: 1.35rem 1.5rem;
  display: flex;
  align-items: center;
  gap: 1.15rem;
  border: 1.5px solid rgba(18, 19, 22, 0.07);
  box-shadow: 0 4px 18px rgba(0, 0, 0, 0.03);
  transition: transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1),
              box-shadow 300ms ease,
              border-color 300ms ease;
  position: relative;
  overflow: hidden;
}

.ds-trust-card-next::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: var(--accent-orange, #E05A2B);
  opacity: 0;
  transition: opacity 300ms ease;
}

.ds-trust-card-next:hover {
  transform: translateY(-5px);
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
  border-color: rgba(224, 90, 43, 0.25);
}

.ds-trust-card-next:hover::before {
  opacity: 1;
}

.ds-trust-card-next__icon-wrap {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  background: rgba(224, 90, 43, 0.08);
  color: var(--accent-orange, #E05A2B);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1),
              background 300ms ease;
}

.ds-trust-card-next:hover .ds-trust-card-next__icon-wrap {
  transform: scale(1.08) rotate(4deg);
  background: var(--accent-orange, #E05A2B);
  color: #FFFFFF;
}

.ds-trust-card-next__text {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.ds-trust-card-next__title {
  font-family: var(--font-body);
  font-size: 0.9375rem;
  font-weight: 700;
  color: #121316;
  margin: 0;
  line-height: 1.25;
}

.ds-trust-card-next__subtitle {
  font-family: var(--font-body);
  font-size: 0.8125rem;
  font-weight: 400;
  color: #555B68;
  margin: 0;
  line-height: 1.4;
}

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .ds-trust-next__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }
}

@media (max-width: 575px) {
  .ds-trust-next { padding: 2.5rem 0 1.5rem; }
  .ds-trust-next__grid { grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
  .ds-trust-card-next {
    padding: 1rem 0.85rem;
    gap: 0.75rem;
    border-radius: 12px;
  }
  .ds-trust-card-next__icon-wrap {
    width: 38px;
    height: 38px;
    border-radius: 10px;
  }
  .ds-trust-card-next__icon-wrap svg {
    width: 18px;
    height: 18px;
  }
  .ds-trust-card-next__title { font-size: 0.8125rem; }
  .ds-trust-card-next__subtitle { font-size: 0.75rem; }
}
</style>

{% schema %}
{
  "name": "Trust Bar",
  "tag": "section",
  "class": "section-trust-bar",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Worldwide Shipping"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "World Wide Free Shipping"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "title": "Worldwide Shipping",
            "subtitle": "World Wide Free Shipping"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "title": "Secured Payment",
            "subtitle": "Safe & Secured Payments"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "title": "30 Days Free Returns",
            "subtitle": "Within 30 Days For Exchange"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "title": "Surprise Gift",
            "subtitle": "Free gift worth for customers"
          }
        }
      ]
    }
  ]
}
{% endschema %}
