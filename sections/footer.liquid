{%- comment -%}
  Section: Footer (Foesta Modern Edition)
  Clean 4-column footer with brand summary, quick links, info links, contact details,
  payment badge icons, and copyright.
{%- endcomment -%}

<footer class="ds-footer-foesta" id="section-{{ section.id }}">
  <div class="ds-container">

    {%- comment -%} Top Row: 4 Columns {%- endcomment -%}
    <div class="ds-footer-foesta__top">
      
      {%- comment -%} Col 1: Brand Info {%- endcomment -%}
      <div class="ds-footer-foesta__col">
        <h3 class="ds-footer-foesta__logo">
          {{ shop.name | default: 'foesta.' }}
        </h3>
        <p class="ds-footer-foesta__text">
          Foesta is a modern luxury ecommerce dropshipping store bringing you trending fashion, quality home décor, gifts, and lifestyle accessories.
        </p>
      </div>

      {%- comment -%} Col 2: Quick Links {%- endcomment -%}
      <div class="ds-footer-foesta__col">
        <h4 class="ds-footer-foesta__heading">Quick Links</h4>
        <ul class="ds-footer-foesta__list">
          <li><a href="/collections/all">Shop All Products</a></li>
          <li><a href="/collections">Featured Collections</a></li>
          <li><a href="/pages/about-us">About Our Brand</a></li>
          <li><a href="/blogs/news">Latest Blog Articles</a></li>
        </ul>
      </div>

      {%- comment -%} Col 3: Information {%- endcomment -%}
      <div class="ds-footer-foesta__col">
        <h4 class="ds-footer-foesta__heading">Information</h4>
        <ul class="ds-footer-foesta__list">
          <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
          <li><a href="/policies/terms-of-service">Terms of Service</a></li>
          <li><a href="/policies/shipping-policy">Shipping & Delivery</a></li>
          <li><a href="/policies/refund-policy">Returns & Exchanges</a></li>
        </ul>
      </div>

      {%- comment -%} Col 4: Get In Touch {%- endcomment -%}
      <div class="ds-footer-foesta__col">
        <h4 class="ds-footer-foesta__heading">Get In Touch</h4>
        <ul class="ds-footer-foesta__list ds-footer-foesta__list--contact">
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            +1 (800) 123 - 4567
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            support@foestastore.com
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            123 Fashion Street, New York, US
          </li>
        </ul>
      </div>

    </div>

    {%- comment -%} Bottom Strip: Copyright & Payment Badges {%- endcomment -%}
    <div class="ds-footer-foesta__bottom">
      <p class="ds-footer-foesta__copyright">
        © {{ 'now' | date: '%Y' }} {{ shop.name }}. All Rights Reserved. Designed for Luxury Ecommerce.
      </p>

      <div class="ds-footer-foesta__payment">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'ds-footer-foesta__payment-svg' }}
        {%- else -%}
          <span class="ds-footer-foesta__payment-text">🔒 256-bit SSL Secure Checkout</span>
        {%- endfor -%}
      </div>
    </div>

  </div>
</footer>

<style>
/* ═══ FOOTER (FOESTA EDITION) ═══ */
.ds-footer-foesta {
  background: #FFFFFF;
  border-top: 1px solid var(--color-border);
  padding-top: 4.5rem;
  padding-bottom: 2rem;
}

.ds-footer-foesta__top {
  display: grid;
  grid-template-columns: 1.2fr 1fr 1fr 1.2fr;
  gap: var(--grid-gap-lg);
  padding-bottom: 3.5rem;
  border-bottom: 1px solid var(--color-border-light);
}

.ds-footer-foesta__logo {
  font-family: var(--font-heading);
  font-size: 1.75rem;
  font-weight: 800;
  color: #121316;
  margin: 0 0 var(--space-4);
  letter-spacing: -0.02em;
}

.ds-footer-foesta__text {
  font-family: var(--font-body);
  font-size: var(--font-size-xs);
  color: #555B68;
  line-height: 1.65;
  margin: 0;
}

.ds-footer-foesta__heading {
  font-family: var(--font-body);
  font-size: var(--font-size-xs);
  font-weight: 700;
  letter-spacing: 0.04em;
  color: #121316;
  margin: 0 0 var(--space-4);
}

.ds-footer-foesta__list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.ds-footer-foesta__list a {
  font-family: var(--font-body);
  font-size: var(--font-size-xs);
  color: #555B68;
  transition: color 200ms ease;
}

.ds-footer-foesta__list a:hover {
  color: var(--color-accent-gold);
}

.ds-footer-foesta__list--contact li {
  font-family: var(--font-body);
  font-size: var(--font-size-xs);
  color: #555B68;
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

/* Bottom Strip */
.ds-footer-foesta__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 2rem;
  flex-wrap: wrap;
  gap: var(--space-4);
}

.ds-footer-foesta__copyright {
  font-family: var(--font-body);
  font-size: var(--font-size-3xs);
  color: #8E95A2;
  margin: 0;
}

.ds-footer-foesta__payment {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.ds-footer-foesta__payment-text {
  font-family: var(--font-body);
  font-size: var(--font-size-3xs);
  color: #8E95A2;
}

@media (max-width: 1023px) {
  .ds-footer-foesta__top {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--grid-gap-md);
  }
}

@media (max-width: 639px) {
  .ds-footer-foesta__top {
    grid-template-columns: 1fr;
  }
  .ds-footer-foesta__bottom {
    flex-direction: column;
    text-align: center;
  }
}
</style>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "class": "section-footer",
  "settings": []
}
{% endschema %}
